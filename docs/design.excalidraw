      "link": null,
      "locked": false,
      "text": "@dataclass\nclass HandoffContext:\n    from_agent:    str\n    status:        HandoffStatus   # NEW | RETURN\n    reason:        str             # short label → shapes greeting tone only\n    session_state: dict            # structured facts from agent._state\n    metadata:      dict            # handoff flags",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "@dataclass\nclass HandoffContext:\n    from_agent:    str\n    status:        HandoffStatus   # NEW | RETURN\n    reason:        str             # short label → shapes greeting tone only\n    session_state: dict            # structured facts from agent._state\n    metadata:      dict            # handoff flags",
      "lineHeight": 1.25,
      "index": "b0E",
      "frameId": null,
      "autoResize": true
    },
    {
      "id": "secE-note",
      "type": "text",
      "x": 945,
      "y": 1164,
      "width": 790,
      "height": 78,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 78,
      "version": 2,
      "versionNonce": 1182868126,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772418585832,
      "link": null,
      "locked": false,
      "text": "Note: Conversation history is NOT in HandoffContext.\nLiveKit's AgentSession carries the full transcript automatically across handoffs.\nreason is a short label only — to shape the greeting tone.",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Note: Conversation history is NOT in HandoffContext.\nLiveKit's AgentSession carries the full transcript automatically across handoffs.\nreason is a short label only — to shape the greeting tone.",
      "lineHeight": 1.25,
      "index": "b0F",
      "frameId": null,
      "autoResize": true
    },
