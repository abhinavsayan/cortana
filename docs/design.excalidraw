    {
      "id": "secF-body",
      "type": "text",
      "x": 80,
      "y": 1316,
      "width": 760,
      "height": 208,
      "angle": 0,
      "strokeColor": "#1a6b27",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
