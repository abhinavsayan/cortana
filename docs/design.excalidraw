      "seed": 82,
      "version": 2,
      "versionNonce": 2087949086,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772418585832,
      "link": null,
      "locked": false,
      "text": "Class variables:  voice_profile, stt_profile, llm_profile, instructions\n\non_enter()       → swaps session plugins to this agent's declared profiles → calls greet()\ngreet(ctx)       → generates contextual opening based on handoff status\non_exit()        → logs active_time\nupdate_state()   → accumulates structured facts into _state dict\n\nPlugin Factories  (config/profiles.py)\n  build_tts(profile: VoiceProfile) → TTS    Adding a new provider = one new elif\n  build_stt(profile: STTProfile)   → STT    in the factory, no changes to agents\n  build_llm(profile: LLMProfile)   → LLM",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Class variables:  voice_profile, stt_profile, llm_profile, instructions\n\non_enter()       → swaps session plugins to this agent's declared profiles → calls greet()\ngreet(ctx)       → generates contextual opening based on handoff status\non_exit()        → logs active_time\nupdate_state()   → accumulates structured facts into _state dict\n\nPlugin Factories  (config/profiles.py)\n  build_tts(profile: VoiceProfile) → TTS    Adding a new provider = one new elif\n  build_stt(profile: STTProfile)   → STT    in the factory, no changes to agents\n  build_llm(profile: LLMProfile)   → LLM",
      "lineHeight": 1.25,
      "index": "b0J",
      "frameId": null,
      "autoResize": true
    },
